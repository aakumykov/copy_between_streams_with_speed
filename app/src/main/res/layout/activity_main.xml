<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/selectFileButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/select_a_file" />
        <ImageButton
            android:id="@+id/clearSelectionButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="0"
            android:src="@drawable/ic_close"
            tools:ignore="ContentDescription" />
    </LinearLayout>

    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="0"
        android:backgroundTint="#4DB6AC"
        android:textColor="@color/white"
        android:text="Старт" />

    <Button
        android:id="@+id/stopButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="0"
        android:backgroundTint="#FFA726"
        android:textColor="@color/white"
        android:text="Стоп" />

    <TextView
        android:id="@+id/fileInfoView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:padding="2dp"
        tools:text="Выбранный файл" />

    <com.github.aakumykov.seek_bar_with_text_input.SeekBarWithTextInput
        android:id="@+id/speedSlider"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        app:max="1048576"
        app:progress="102400"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_weight="0">

        <ToggleButton
            android:id="@+id/noSpeedLimitToggle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:textOn="Без ограничения скорости"
            android:textOff="Заданная скорость"/>

        <ToggleButton
            android:id="@+id/debugToggle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="0"
            android:checked="false"
            android:textAllCaps="false"
            android:textOff="Отладки нет"
            android:textOn="Отладка есть"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="invisible"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="0">
        <TextView
            android:id="@+id/estimatedTimeView"
            style="@style/horizontal_cell"
            android:background="#F0F4C3"
            android:textAlignment="center"
            tools:text="Ожидаемое время"/>
        <TextView
            android:id="@+id/realTimeView"
            style="@style/horizontal_cell"
            android:background="#C8E6C9"
            android:textAlignment="center"
            tools:text="Потраченное время" />
    </LinearLayout>

    <TextView
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="2dp"
        android:textColor="@color/error"
        android:focusable="false"
        tools:text="Ошибка" />

    <ScrollView
        android:id="@+id/infoScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="false">
        <TextView
            android:id="@+id/infoView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:textSize="12sp"
            android:focusable="false"
            tools:text="Инфа" />
    </ScrollView>

</LinearLayout>